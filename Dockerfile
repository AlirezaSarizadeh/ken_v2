# 1. انتخاب محیط پایه (یه نسخه سبک از لینوکس که نود روش نصبه)
FROM node:20-alpine

# 2. ساخت پوشه کاری داخل کانتینر
WORKDIR /app

# 3. کپی کردن فایل‌های پکیج (برای نصب وابستگی‌ها)
COPY package*.json ./

# 4. نصب وابستگی‌ها
RUN npm install

# 5. کپی کردن بقیه فایل‌های پروژه به داخل کانتینر
COPY . .

# 6. بیلد گرفتن پروژه نکست
RUN npm run build

# 7. باز کردن پورت ۳۰۰۰ (پورتی که نکست روش اجرا میشه)
EXPOSE 3000

# 8. دستور نهایی برای روشن شدن برنامه
CMD ["npm", "start"]